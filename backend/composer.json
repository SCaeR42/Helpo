{
    "name": "helpo/backend",
    "description": "Helpo API - Slim Framework Backend",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "firebase/php-jwt": "^6.10",
        "php-amqplib/php-amqplib": "^3.5",
        "monolog/monolog": "^3.4",
        "webonyx/graphql-php": "^15.6",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.4"
    },
    "config": {
        "platform": {
            "php": "8.2",
            "ext-sockets": "1.0"
        },
        "allow-plugins": {
            "php-http/discovery": true
        },
        "audit": {
            "abandoned": "report",
            "ignore": [
                "PKSA-y2cr-5h3j-g3ys"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public",
        "test": "vendor/bin/phpunit"
    }
}
